generator client {
  provider   = "prisma-client"
  output     = "../generated/prisma"
  engineType = "client"
}

datasource db {
  provider = "sqlite"
}

// ——— 枚举 ———

enum ModelType {
  LLM
  IMAGE
  SEARCH
}

enum ProviderType {
  OPENAI
  OPENAI_COMPATIBLE
  ALIBABA
  BRAVE_SEARCH
  VOLCENGINE_SEEDREAM
  DASHSCOPE_WAN_IMAGE
}

enum ImageSource {
  USER_UPLOAD
  GENERATED
  URL_FETCHED
}

enum SearchTool {
  WEB_SEARCH
  IMAGE_SEARCH
}

enum MessageRole {
  USER
  ASSISTANT
  SYSTEM
}

/// M1 仅写入 LLM；IMAGE_PRIMARY / IMAGE_SECONDARY 为 M3 占位
enum SelectionRole {
  LLM
  IMAGE_PRIMARY
  IMAGE_SECONDARY
}

// ——— 表 ———

model Model {
  id           String    @id @default(cuid())
  type         ModelType
  name         String
  providerType ProviderType
  /// LLM: 必须由 app 层校验非空；IMAGE/SEARCH: 按各自需求
  baseURL      String?
  apiKey       String
  /// LLM 必填（app 层校验），其他类型 null
  contextWindow Int?
  extraHeaders Json?
  capabilities Json?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  messages        Message[]
  selections      ConversationModelSelection[]
  searchBindings  SearchToolBinding[]
  generatedImages Image[]
}

model Conversation {
  id        String    @id @default(cuid())
  title     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  messages   Message[]
  selections ConversationModelSelection[]
  images     Image[]
}

model Message {
  id                String      @id @default(cuid())
  conversationId    String
  role              MessageRole
  content           String
  /// M2: UIMessage parts JSON；M1 旧消息保持 null
  parts             Json?
  usageInputTokens  Int?
  usageOutputTokens Int?
  usageTotalTokens  Int?
  modelIdAtTime     String?
  createdAt         DateTime    @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  /// 删除 Model 时保留历史消息，仅把引用清空
  model        Model?       @relation(fields: [modelIdAtTime], references: [id], onDelete: SetNull)
}

model ConversationModelSelection {
  id             String        @id @default(cuid())
  conversationId String
  role           SelectionRole
  modelId        String
  /// M3: IMAGE_* 存 { size: '2048x2048' }；LLM 为 null
  params         Json?
  createdAt      DateTime      @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  /// 删除 Model 时，关联选择也一并删除，保持选择一致性
  model        Model        @relation(fields: [modelId], references: [id], onDelete: Cascade)

  @@unique([conversationId, role])
}

model Image {
  id             String      @id @default(cuid())
  conversationId String
  source         ImageSource
  mimeType       String
  sizeBytes      Int
  width          Int?
  height         Int?
  /// 仅 GENERATED 时非 null（app 层校验）；删除 Model 时保留历史图像记录
  modelIdAtTime  String?
  /// 仅 URL_FETCHED 时非 null（app 层校验）
  originalUrl    String?
  createdAt      DateTime    @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  model        Model?       @relation(fields: [modelIdAtTime], references: [id], onDelete: SetNull)
}

model SearchToolBinding {
  id        String     @id @default(cuid())
  tool      SearchTool @unique
  modelId   String
  createdAt DateTime   @default(now())

  model Model @relation(fields: [modelId], references: [id], onDelete: Cascade)
}
